# ACT4 smoke-test build artifact (see tests/arch-tests/smoke/fail.S and the
# arch-tests-smoke Makefile target). The upstream ACT4 build output lives
# under third-party/riscv-arch-test/ and is ignored via the submodule.
smoke/*.elf
smoke/*.o

